# DevOSRing - LLM credentials
#
# Copy this file to `.env` and fill in your key. Then run:
#   ./scripts/setup-llm.sh
# to write the values into ~/.devos/llm.json (consumed by all 4 plugins).
#
# `.env` itself is gitignored and never committed.

LLM_API_KEY=
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
